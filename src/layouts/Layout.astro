---
interface Props {
  title: string;
  description?: string;
}
const { title, description = '我的个人网站' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-amber-50 text-gray-900 min-h-screen font-sans">
    <!-- 导航栏 -->
    <nav class="fixed top-0 w-full z-50 bg-amber-50 border-b-4 border-black">
      <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-xl font-black uppercase tracking-tight hover:text-rose-500 transition-colors">
          ✦ 我的主页
        </a>
        <div class="flex gap-6 text-sm font-bold">
          <a href="/#about" class="hover:text-rose-500 transition-colors border-b-2 border-transparent hover:border-rose-500 pb-1">关于</a>
          <a href="/#projects" class="hover:text-rose-500 transition-colors border-b-2 border-transparent hover:border-rose-500 pb-1">项目</a>
          <a href="/wiki" class="hover:text-rose-500 transition-colors border-b-2 border-transparent hover:border-rose-500 pb-1">知识库</a>
          <a href="/search" class="hover:text-white transition">搜索</a>
          <a href="/#contact" class="hover:text-rose-500 transition-colors border-b-2 border-transparent hover:border-rose-500 pb-1">联系</a>
        </div>
      </div>
    </nav>

    <!-- 主内容 -->
    <main class="pt-20">
      <slot />
    </main>

    <!-- 页脚 -->
    <footer class="border-t-4 border-black mt-24 py-8 text-center text-gray-600 font-bold">
      <p>© 2025 · Built with Astro & ❤️</p>
    </footer>
  </body>
</html>