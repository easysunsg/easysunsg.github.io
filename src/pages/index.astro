---
import Layout from '../layouts/Layout.astro';
---

<Layout title="我的个人网站">

  <!-- Hero 区块 -->
  <section class="min-h-screen flex flex-col justify-center items-center text-center px-6">
    <div class="max-w-2xl">
      <p class="text-sm font-black uppercase tracking-widest mb-4 bg-rose-500 text-white px-4 py-2 inline-block border-2 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">Hello, World 👋</p>
      <h1 class="text-6xl font-black mb-6 leading-tight">
        我是 <span class="bg-teal-400 px-2 border-b-4 border-black">你的名字</span>
      </h1>
      <p class="text-lg mb-10 font-medium text-gray-700">
        一句话介绍自己，比如：全栈开发者 / 设计师 / 终身学习者。<br/>
        热爱构建有趣的东西。
      </p>
      <div class="flex gap-4 justify-center">
        <a href="#projects" class="bg-rose-500 hover:bg-rose-600 text-white px-8 py-4 font-black border-4 border-black shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[-2px] hover:translate-y-[-2px] transition-all">
          查看项目 →
        </a>
        <a href="/wiki" class="bg-amber-200 hover:bg-amber-300 text-black px-8 py-4 font-black border-4 border-black shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[-2px] hover:translate-y-[-2px] transition-all">
          知识库
        </a>
      </div>
    </div>
  </section>

  <!-- 关于我 -->
  <section id="about" class="max-w-5xl mx-auto px-6 py-24">
    <h2 class="text-5xl font-black mb-8 border-l-8 border-teal-400 pl-4">关于我</h2>
    <div class="grid md:grid-cols-2 gap-12">
      <div class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)]">
        <p class="font-medium text-gray-700 leading-relaxed">
          这里写你的自我介绍，可以包括你的背景、经历、兴趣爱好等。
          让访客快速了解你是谁。
        </p>
      </div>
      <div class="bg-amber-200 border-4 border-black p-8 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)]">
        <p class="font-medium text-gray-800 leading-relaxed">
          这里可以写你的技能、正在做的事情，或者你的价值观。
          真实的文字比模板更有感染力。
        </p>
      </div>
    </div>
  </section>

  <!-- 项目展示 -->
  <section id="projects" class="max-w-5xl mx-auto px-6 py-24">
    <h2 class="text-5xl font-black mb-8 border-l-8 border-teal-400 pl-4">项目</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { title: '项目名称 1', desc: '项目简介，一两句话描述做了什么', tag: 'TypeScript', link: '#', color: 'bg-rose-500' },
        { title: '项目名称 2', desc: '项目简介，一两句话描述做了什么', tag: 'Python', link: '#', color: 'bg-teal-400' },
        { title: '项目名称 3', desc: '项目简介，一两句话描述做了什么', tag: 'Astro', link: '#', color: 'bg-amber-200' },
      ].map(p => (
        <a href={p.link} class="group block bg-white border-4 border-black p-6 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[-2px] hover:translate-y-[-2px] transition-all">
          <h3 class="font-black text-xl mb-3 group-hover:text-teal-500 transition-colors">{p.title}</h3>
          <p class="text-gray-600 mb-4 font-medium">{p.desc}</p>
          <span class={`text-xs text-black px-4 py-2 font-black uppercase tracking-wide ${p.color} border-2 border-black`}>{p.tag}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- 联系方式 -->
  <section id="contact" class="max-w-5xl mx-auto px-6 py-24">
    <h2 class="text-5xl font-black mb-4 border-l-8 border-teal-400 pl-4">联系我</h2>
    <p class="text-lg font-medium text-gray-700 mb-8">有任何想法或合作意向，欢迎联系！</p>
    <div class="flex gap-4 flex-wrap">
      <a href="mailto:your@email.com" class="bg-white border-4 border-black px-8 py-4 font-black shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[-2px] hover:translate-y-[-2px] transition-all hover:bg-rose-500 hover:text-white">
        📧 Email
      </a>
      <a href="https://github.com/your-username" class="bg-white border-4 border-black px-8 py-4 font-black shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[-2px] hover:translate-y-[-2px] transition-all hover:bg-teal-400 hover:text-black">
        🐙 GitHub
      </a>
    </div>
  </section>

</Layout>