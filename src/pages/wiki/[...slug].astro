---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allArticles = await getCollection('wiki');

  return allArticles.map(entry => ({
    params: {
      slug: entry.id.replace(/\\/g, '/'),
    },
    props: {
      entry,
    },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const title = entry.data.title;
const description = entry.data.description ?? '';
const tags = entry.data.tags ?? [];
const date = entry.data.date
  ? new Date(entry.data.date).toLocaleDateString('zh-CN')
  : '';
---

<Layout title={title}>
  <article class="max-w-4xl mx-auto px-6 py-16">

    <!-- 返回按钮 -->
    <a
      href="/wiki"
      class="inline-flex items-center gap-2 text-gray-700 hover:text-teal-500 transition-colors mb-8 font-black border-4 border-black bg-white px-6 py-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[-2px] hover:translate-y-[-2px]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
      </svg>
      返回列表
    </a>

    <!-- 文章标题 -->
    <header class="mb-10">
      <h1 class="text-5xl font-black mb-6 border-l-8 border-teal-400 pl-4">{title}</h1>

      <div class="flex flex-wrap items-center gap-4">
        {date && (
          <span class="flex items-center gap-2 font-bold text-gray-700 bg-amber-200 px-4 py-2 border-2 border-black">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
            </svg>
            {date}
          </span>
        )}

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => (
              <span class="font-black uppercase tracking-wide bg-rose-500 text-white px-4 py-2 border-2 border-black text-xs">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- 文章内容 -->
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    <!-- 底部导航 -->
    <div class="mt-16 pt-8 border-t-4 border-black">
      <a
        href="/wiki"
        class="inline-flex items-center gap-2 font-black text-teal-500 hover:text-teal-600 transition-colors border-4 border-black bg-white px-6 py-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[-2px] hover:translate-y-[-2px]"
      >
        ← 返回知识库列表
      </a>
    </div>

  </article>
</Layout>

<style is:global>
  .prose h1 {
    @apply text-4xl font-black text-gray-900 mt-10 mb-5 border-l-4 border-teal-400 pl-4;
  }
  .prose h2 {
    @apply text-3xl font-black text-gray-900 mt-10 mb-5 border-l-4 border-rose-500 pl-4;
  }
  .prose h3 {
    @apply text-2xl font-black text-gray-900 mt-8 mb-4;
  }
  .prose p {
    @apply text-gray-700 leading-relaxed mb-5 font-medium text-lg;
  }
  .prose a {
    @apply text-teal-600 hover:text-rose-500 underline underline-4 decoration-2 underline-offset-2 font-bold transition-colors;
  }
  .prose code {
    @apply bg-amber-200 text-gray-900 px-2 py-1 border-2 border-black font-bold text-sm;
  }
  .prose pre {
    @apply bg-white border-4 border-black p-5 mb-6 overflow-x-auto shadow-[4px_4px_0px_0px_rgba(0,0,0,1)];
  }
  .prose pre code {
    @apply bg-transparent text-gray-900 px-0 py-0 border-0;
  }
  .prose ul, .prose ol {
    @apply text-gray-700 pl-6 mb-5 list-disc font-medium text-lg;
  }
  .prose blockquote {
    @apply border-l-4 border-rose-500 pl-4 text-gray-700 italic my-5 bg-amber-100 py-3;
  }
  .prose img {
    @apply border-4 border-black my-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)];
  }
  .prose hr {
    @apply border-b-4 border-black my-10;
  }
</style>
