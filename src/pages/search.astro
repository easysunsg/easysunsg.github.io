---
import Layout from '../layouts/Layout.astro';
---

<Layout title="搜索">
    <div class="md-container">
        <!-- Hero Banner -->
        <div class="md-banner">
            <h1>搜索 🔍</h1>
            <p>搜索知识库中的所有文章</p>
        </div>

        <!-- Search Container Card -->
        <div class="md-card md-card-large">
            <!-- Pagefind 搜索框会自动注入这里 -->
            <div id="search" class="pagefind-ui-wrapper"></div>
        </div>
    </div>
</Layout>

<!-- Deleted:<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />-->
<!-- Deleted:<script src="/pagefind/pagefind-ui.js" is:inline></script>-->
<script is:inline>
    // 动态加载 Pagefind 资源，仅在构建后生效
    const loadPagefind = async () => {
        try {
            // 动态创建 link 标签加载 CSS
            const link = document.createElement('link');
            link.rel = 'stylesheet';
            link.href = '/pagefind/pagefind-ui.css';
            document.head.appendChild(link);

            // 动态创建 script 标签加载 JS
            const script = document.createElement('script');
            script.src = '/pagefind/pagefind-ui.js';
            script.onload = () => {
                // @ts-ignore - PagefindUI 类型由 pagefind 库提供
                new PagefindUI({
                    element: '#search',
                    showImages: false,
                    translations: {
                        placeholder: '搜索文章...',
                        zero_results: '没有找到相关文章',
                    }
                });
            };
            script.onerror = () => {
                console.warn('Pagefind 资源未找到，请确保已运行构建命令：pnpm build');
                document.getElementById('search').innerHTML = '<p class="md-text-muted">搜索功能将在构建后可用。开发模式下请先访问 /search 预览。</p>';
            };
            document.head.appendChild(script);
        } catch (error) {
            console.error('加载 Pagefind 失败:', error);
        }
    };

    window.addEventListener('DOMContentLoaded', loadPagefind);
</script>

<style>
    :global {
        :root {
            --bg-color: #F4EFEA;
            --text-main: #383838;
            --yellow-accent: #FFDE00;
            --orange-accent: #FF9538;
            --surface-white: #FFFFFF;
            --focus-ring: #6FC2FF;
        }
    }

    .md-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    /* Hero Banner */
    .md-banner {
        background: var(--yellow-accent);
        border: 2px solid var(--text-main);
        border-radius: 20px;
        padding: 60px;
        margin-bottom: 60px;
        box-shadow: 8px 8px 0px var(--text-main);
    }

    .md-banner h1 {
        font-family: 'Aeonik Mono', 'Roboto Mono', monospace;
        font-size: 4rem;
        font-weight: 700;
        line-height: 1.1;
        margin-bottom: 16px;
        color: var(--text-main);
    }

    .md-banner p {
        font-family: 'Inter', sans-serif;
        font-size: 1.25rem;
        color: var(--text-main);
    }

    /* Search Card */
    .md-card {
        background: var(--surface-white);
        border: 2px solid var(--text-main);
        border-radius: 16px;
        padding: 40px;
        box-shadow: 6px 6px 0px var(--text-main);
    }

    .md-card-large {
        max-width: 800px;
        margin: 0 auto;
    }

    /* Pagefind UI Wrapper */
    .pagefind-ui-wrapper {
        padding: 20px;
    }

    /* Text Styles */
    .md-text-muted {
        font-family: 'Inter', sans-serif;
        color: var(--text-main);
        opacity: 0.6;
        text-align: center;
        padding: 40px;
    }

    /* Pagefind UI Overrides - Neo-Brutalist Style */
    :global(#search) {
        --pagefind-ui-primary: var(--text-main);
        --pagefind-ui-text: var(--text-main);
        --pagefind-ui-background: var(--surface-white);
        --pagefind-ui-border: var(--text-main);
        --pagefind-ui-tag: var(--yellow-accent);
        --pagefind-ui-font: 'Inter', sans-serif;
    }

    :global(#search .pagefind-ui__search-input) {
        border: 2px solid var(--text-main) !important;
        border-radius: 8px !important;
        padding: 12px 16px !important;
        box-shadow: 4px 4px 0px var(--text-main) !important;
        font-family: 'Inter', sans-serif !important;
        font-size: 14px !important;
        transition: all 0.2s ease !important;
    }

    :global(#search .pagefind-ui__search-input:focus) {
        outline: 3px solid var(--focus-ring) !important;
        outline-offset: 2px !important;
    }

    :global(#search .pagefind-ui__result) {
        border: 2px solid var(--text-main) !important;
        border-radius: 12px !important;
        margin-bottom: 16px !important;
        padding: 20px !important;
        box-shadow: 4px 4px 0px var(--text-main) !important;
        transition: all 0.2s ease !important;
    }

    :global(#search .pagefind-ui__result:hover) {
        transform: translateY(-2px) !important;
        box-shadow: 6px 6px 0px var(--text-main) !important;
    }

    :global(#search .pagefind-ui__result-title) {
        font-family: 'Aeonik Mono', 'Roboto Mono', monospace !important;
        font-weight: 700 !important;
        color: var(--text-main) !important;
        text-decoration: none !important;
    }

    :global(#search .pagefind-ui__result-title:hover) {
        color: var(--orange-accent) !important;
    }

    :global(#search .pagefind-ui__result-excerpt) {
        font-family: 'Inter', sans-serif !important;
        color: var(--text-main) !important;
        opacity: 0.8 !important;
    }

    :global(#search .pagefind-ui__result-match) {
        background: var(--yellow-accent) !important;
        color: var(--text-main) !important;
        padding: 0 4px !important;
        border-radius: 4px !important;
        font-weight: 600 !important;
    }

    :global(#search .pagefind-ui__drawer) {
        border: 2px solid var(--text-main) !important;
        border-radius: 16px !important;
        box-shadow: 8px 8px 0px var(--text-main) !important;
    }

    :global(#search .pagefind-ui__filter-clear) {
        border: 2px solid var(--text-main) !important;
        border-radius: 8px !important;
        padding: 8px 16px !important;
        background: var(--surface-white) !important;
        color: var(--text-main) !important;
        box-shadow: 2px 2px 0px var(--text-main) !important;
        font-family: 'Inter', sans-serif !important;
        font-weight: 600 !important;
        transition: all 0.2s ease !important;
    }

    :global(#search .pagefind-ui__filter-clear:hover) {
        transform: translate(1px, 1px) !important;
        box-shadow: 1px 1px 0px var(--text-main) !important;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .md-container {
            padding: 16px;
        }

        .md-banner {
            padding: 40px 24px;
            margin-bottom: 40px;
        }

        .md-banner h1 {
            font-size: 2.5rem;
        }

        .md-banner p {
            font-size: 1rem;
        }

        .md-card {
            padding: 24px;
        }
    }
</style>
