---
import Layout from '../layouts/Layout.astro';
---

<Layout title="搜索">
    <div class="max-w-4xl mx-auto px-6 py-16">
        <!-- 页头 -->
        <div class="mb-12">
            <h1 class="text-5xl font-black mb-4 border-l-8 border-teal-400 pl-4">搜索 🔍</h1>
            <p class="text-lg font-medium text-gray-700">在知识库中查找你需要的内容</p>
        </div>

        <!-- 搜索卡片 -->
        <div class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)]">
            <!-- Pagefind 搜索框会自动注入这里 -->
            <div id="search" class="pagefind-ui"></div>
        </div>

        <!-- 搜索提示（仅在未搜索时显示） -->
        <div id="search-placeholder" class="mt-8 text-center">
            <p class="text-gray-600 font-medium">💡 输入关键词开始搜索，支持标题和内容搜索</p>
        </div>

        <!-- 搜索结果统计 -->
        <div id="search-stats" class="mt-6 text-center" style="display: none;">
            <p class="text-gray-700 font-medium">
                找到 <span id="result-count" class="text-xl font-black text-teal-500"></span> 个结果
            </p>
        </div>
    </div>
</Layout>

<script is:inline>
    // 动态加载 Pagefind 资源，仅在构建后生效
    const loadPagefind = async () => {
        try {
            // 动态创建 link 标签加载 CSS
            const link = document.createElement('link');
            link.rel = 'stylesheet';
            link.href = '/pagefind/pagefind-ui.css';
            document.head.appendChild(link);

            // 动态创建 script 标签加载 JS
            const script = document.createElement('script');
            script.src = '/pagefind/pagefind-ui.js';
            script.onload = () => {
                // @ts-ignore - PagefindUI 类型由 pagefind 库提供
                window.pagefindUI = new PagefindUI({
                    element: '#search',
                    showImages: false,
                    translations: {
                        placeholder: '输入关键词搜索...',
                        zero_results: '没有找到相关文章',
                    },
                    showEmpty: true
                });

                // 监听搜索结果变化
                setTimeout(() => {
                    const searchInput = document.querySelector('.pagefind-ui__search-input');
                    const searchResults = document.querySelector('.pagefind-ui__results');
                    const searchPlaceholder = document.getElementById('search-placeholder');
                    const searchStats = document.getElementById('search-stats');
                    const resultCount = document.getElementById('result-count');

                    if (searchInput) {
                        searchInput.addEventListener('input', () => {
                            const hasValue = searchInput.value.length > 0;

                            if (hasValue) {
                                searchPlaceholder.style.display = 'none';
                                searchStats.style.display = 'block';
                            } else {
                                searchPlaceholder.style.display = 'block';
                                searchStats.style.display = 'none';
                            }

                            // 更新结果统计
                            if (searchResults) {
                                const results = searchResults.querySelectorAll('.pagefind-ui__result');
                                const count = results.length;
                                if (hasValue) {
                                    resultCount.textContent = count;
                                }
                            }
                        });
                    }
                }, 1000);
            };
            script.onerror = () => {
                console.warn('Pagefind 资源未找到，请确保已运行构建命令：pnpm build');
                const searchContainer = document.getElementById('search');
                searchContainer.innerHTML = `
                    <div class="text-center py-12">
                        <div class="inline-block bg-amber-200 border-4 border-black px-8 py-4 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] mb-6">
                            <svg class="w-16 h-16 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <h3 class="text-2xl font-black mb-2">搜索功能暂时不可用</h3>
                            <p class="text-gray-700 font-medium mb-4">请先运行构建命令：</p>
                            <code class="bg-white border-2 border-black px-3 py-1 font-black">pnpm build</code>
                        </div>
                        <p class="text-gray-600 font-medium">开发模式下可访问 <code class="bg-gray-200 px-2 py-1 border border-gray-400">/search</code> 预览</p>
                    </div>
                `;
            };
            document.head.appendChild(script);
        } catch (error) {
            console.error('加载 Pagefind 失败:', error);
        }
    };

    window.addEventListener('DOMContentLoaded', loadPagefind);
</script>

<style>
    /* Pagefind UI 覆盖样式 - 与项目风格保持一致 */
    :global(#search) {
        --pagefind-ui-primary: #000000;
        --pagefind-ui-text: #374151;
        --pagefind-ui-background: #ffffff;
        --pagefind-ui-border: #000000;
        --pagefind-ui-active: #000000;
    }

    :global(.pagefind-ui__search-input) {
        width: 100%;
        padding: 1rem 1.5rem;
        font-size: 1rem;
        font-weight: 600;
        border: 4px solid #000000;
        border-radius: 0;
        background: #ffffff;
        transition: all 0.2s ease;
        box-shadow: none;
    }

    :global(.pagefind-ui__search-input:focus) {
        outline: none;
        border-color: #000000;
        box-shadow: 0 0 0 4px rgba(0, 0, 0, 0.1);
    }

    :global(.pagefind-ui__results) {
        margin-top: 3rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    :global(.pagefind-ui__result) {
        padding: 2rem;
        background: #ffffff;
        border: 4px solid #000000;
        border-radius: 0;
        transition: all 0.2s ease;
        cursor: pointer;
        box-shadow: 6px 6px 0px rgba(0, 0, 0, 1);
    }

    :global(.pagefind-ui__result:hover) {
        transform: translateX(-4px) translateY(-4px);
        box-shadow: 8px 8px 0px rgba(0, 0, 0, 1);
    }

    :global(.pagefind-ui__result-title) {
        font-size: 1.25rem;
        font-weight: 900;
        color: #111827;
        margin-bottom: 1rem;
        text-decoration: none;
        display: block;
        transition: color 0.2s ease;
        line-height: 1.3;
    }

    :global(.pagefind-ui__result-title:hover) {
        color: #059669;
    }

    :global(.pagefind-ui__result-excerpt) {
        color: #4b5563;
        font-size: 1rem;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    :global(.pagefind-ui__result-match) {
        color: #dc2626;
        font-weight: 700;
        background: #fecaca;
        padding: 0.125rem 0.375rem;
        border: 2px solid #dc2626;
    }

    :global(.pagefind-ui__filter) {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 4px solid #000000;
    }

    :global(.pagefind-ui__filter-tag) {
        padding: 0.75rem 1.5rem;
        background: #f3f4f6;
        color: #111827;
        border: 4px solid #000000;
        border-radius: 0;
        font-size: 0.875rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: all 0.2s ease;
        cursor: pointer;
    }

    :global(.pagefind-ui__filter-tag:hover) {
        background: #000000;
        color: #ffffff;
        transform: translateX(-2px) translateY(-2px);
        box-shadow: 4px 4px 0px rgba(0, 0, 0, 1);
    }

    :global(.pagefind-ui__filter-tag.active) {
        background: #000000;
        color: #ffffff;
    }

    :global(.pagefind-ui__filter-clear) {
        padding: 0.75rem 1.5rem;
        background: #ffffff;
        color: #111827;
        border: 4px solid #000000;
        border-radius: 0;
        font-size: 0.875rem;
        font-weight: 800;
        cursor: pointer;
        transition: all 0.2s ease;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    :global(.pagefind-ui__filter-clear:hover) {
        background: #ef4444;
        color: #ffffff;
        transform: translateX(-2px) translateY(-2px);
        box-shadow: 4px 4px 0px rgba(0, 0, 0, 1);
    }

    /* Zero results state */
    :global(.pagefind-ui__empty) {
        text-align: center;
        padding: 4rem 2rem;
        background: #fef2f2;
        border: 4px solid #dc2626;
        color: #991b1b;
        font-weight: 600;
        font-size: 1.125rem;
    }

    /* 代码样式统一 */
    :global(code) {
        font-family: 'Courier New', monospace;
        font-weight: 600;
    }
</style>