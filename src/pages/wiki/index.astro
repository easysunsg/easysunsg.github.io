---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('wiki');

const sorted = allArticles.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});

const allTags = [...new Set(sorted.flatMap(a => a.data.tags ?? []))];

const articles = sorted.map(a => {
  const id = a.id.replace(/\\/g, '/');
  const href = '/wiki/' + id;
  const title = a.data.title;
  const description = a.data.description ?? '';
  const tags = a.data.tags ?? [];
  const tagsJson = JSON.stringify(tags);
  const date = a.data.date
    ? new Date(a.data.date).toLocaleDateString('zh-CN')
    : '';
  return { href, title, description, tags, tagsJson, date };
});
---

<Layout title="知识库">
  <div class="max-w-6xl mx-auto px-6 py-16">

    <!-- 页头 -->
    <div class="mb-12">
      <h1 class="text-5xl font-black mb-3 border-l-8 border-teal-400 pl-4">知识库 📚</h1>
      <p class="text-lg font-medium text-gray-700">共 {articles.length} 篇笔记，持续更新中...</p>
    </div>

    <!-- 标签筛选 -->
    <div class="flex flex-wrap gap-2 mb-10" id="tag-filter">
      <button
        data-tag="all"
        class="tag-btn px-6 py-2 text-sm font-black uppercase tracking-wide border-4 border-black bg-rose-500 text-white cursor-pointer transition hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[-2px] hover:translate-y-[-2px]"
      >
        全部
      </button>
      {allTags.map(tag => (
        <button
          data-tag={tag}
          class="tag-btn px-6 py-2 text-sm font-black uppercase tracking-wide border-4 border-black bg-white text-black cursor-pointer transition hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[-2px] hover:translate-y-[-2px] hover:bg-teal-400"
        >
          {tag}
        </button>
      ))}
    </div>

    <!-- 卡片瀑布流 -->
    <div class="columns-1 sm:columns-2 lg:columns-3 gap-5" id="card-grid">
      {articles.map(article => (
        <a
          href={article.href}
          data-tags={article.tagsJson}
          class="wiki-card group block bg-white border-4 border-black p-6 mb-5 break-inside-avoid shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[-2px] hover:translate-y-[-2px] transition-all"
        >
          {article.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-4">
              {article.tags.map(tag => (
                <span class="text-xs font-black uppercase tracking-wide bg-amber-200 text-black px-3 py-1 border-2 border-black">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <h2 class="font-black text-lg mb-3 group-hover:text-teal-500 transition-colors leading-snug">
            {article.title}
          </h2>

          {article.description && (
            <p class="text-gray-600 text-sm leading-relaxed line-clamp-3 font-medium">
              {article.description}
            </p>
          )}

          {article.date && (
            <p class="text-gray-500 text-xs mt-4 font-bold">{article.date}</p>
          )}
        </a>
      ))}
    </div>

  </div>
</Layout>

<script>
  const tagBtns = document.querySelectorAll('.tag-btn');
  const cards = document.querySelectorAll('.wiki-card');

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');

      tagBtns.forEach(b => {
        b.classList.remove('bg-rose-500', 'text-white');
        b.classList.add('bg-white', 'text-black');
      });
      btn.classList.add('bg-rose-500', 'text-white');
      btn.classList.remove('bg-white', 'text-black');

      cards.forEach(card => {
        const cardTags = JSON.parse(card.getAttribute('data-tags') || '[]');
        if (tag === 'all' || cardTags.includes(tag)) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>